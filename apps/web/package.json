{
  "name": "web",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/check-bundle-budgets.mjs",
    "typecheck": "tsc -b --pretty false",
    "generate:api": "cd ../.. && ./hack/openapi-generate.sh",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:visual": "playwright test e2e/visual.spec.ts",
    "test:a11y": "playwright test e2e/a11y.spec.ts",
    "test:performance": "node scripts/performance-smoke.mjs",
    "visual-smoke": "node scripts/visual-smoke.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.21",
    "@radix-ui/react-popover": "^1.1.20",
    "@radix-ui/react-tooltip": "^1.2.13",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.25.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-docs": "^10.5.2",
    "@storybook/react": "^10.5.2",
    "@storybook/react-vite": "^10.5.2",
    "@tailwindcss/vite": "^4.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "oxlint": "^1.74.0",
    "playwright": "^1.61.1",
    "storybook": "^10.5.2",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
