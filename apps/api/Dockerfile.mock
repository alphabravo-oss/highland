FROM golang:1.26-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /out/mock-longhorn-manager ./cmd/mock-longhorn-manager

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /out/mock-longhorn-manager /mock-longhorn-manager
ENV MOCK_LH_ADDR=:9500
EXPOSE 9500
USER nonroot:nonroot
ENTRYPOINT ["/mock-longhorn-manager"]
